# Copy to .env and fill in. For GitHub Actions, add matching names as
# repo Settings > Environments > github-pages > Environment secrets / variables.

# Build/deploy (scripts/build_site.py)
AP_BASE_SITE=https://bobdavies.co.uk

# Speaker search API keys (scripts/pod-api-speaker-search.js)
PODCASTINDEX_KEY=
PODCASTINDEX_SECRET=
LISTENNOTES_KEY=
# Podchaser: use PODCHASER_TOKEN (preferred for Actions) or CLIENT_ID+SECRET (OAuth)
PODCHASER_TOKEN=
PODCHASER_CLIENT_ID=
PODCHASER_CLIENT_SECRET=
